        </mxCell>
        <mxCell id="PWL00Yb_VwdRLP5D82v8-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Чтение&lt;/font&gt;" vertex="1">
